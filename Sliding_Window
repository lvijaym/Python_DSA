def max_sum_2(arr,k):
    curr_sum = sum(arr[:k])
    max_sum = curr_sum
    for i in range(len(arr)-k):
        curr_sum += arr[i+k]- arr[i]
        max_sum = max(max_sum,curr_sum)
    return [max_sum]
