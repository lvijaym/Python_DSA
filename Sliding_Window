🔹 Template 3: Frequency Map (Strings / Distinct)
🧩 Use When:
Character constraints
Distinct / anagram / permutation
def freq_window(s, k):
    window_start = 0
    freq = {}
    result = 0

    for window_end in range(len(s)):
        right = s[window_end]
        freq[right] = freq.get(right, 0) + 1

        while len(freq) > k:
            left = s[window_start]
            freq[left] -= 1
            if freq[left] == 0:
                del freq[left]
            window_start += 1

        result = max(result, window_end - window_start + 1)

    return result

✅ Examples:

Longest substring with K distinct
Fruits into baskets
🔹 Template 4: No Repeat / Last Seen Index
def no_repeat(s):
    window_start = 0
    last_seen = {}
    max_length = 0

    for window_end in range(len(s)):
        char = s[window_end]

        if char in last_seen:
            window_start = max(window_start, last_seen[char] + 1)

        last_seen[char] = window_end
        max_length = max(max_length, window_end - window_start + 1)

    return max_length

✅ Example:

Longest substring without repeating characters
🔹 Template 5: Replace / Flip K Elements
🧩 Trick:
window_size - max_freq <= k
def replace_k(s, k):
    window_start = 0
    max_repeat = 0
    freq = {}
    max_length = 0

    for window_end in range(len(s)):
        char = s[window_end]
        freq[char] = freq.get(char, 0) + 1
        max_repeat = max(max_repeat, freq[char])

        if (window_end - window_start + 1 - max_repeat) > k:
            freq[s[window_start]] -= 1
            window_start += 1

        max_length = max(max_length, window_end - window_start + 1)

    return max_length

✅ Examples:

Longest repeating character replacement
Max consecutive 1s with K flips
🔹 Template 6: Pattern Matching (Anagram / Permutation)
def pattern_match(s, pattern):
    window_start = 0
    matched = 0
    freq = {}

    for ch in pattern:
        freq[ch] = freq.get(ch, 0) + 1

    for window_end in range(len(s)):
        right = s[window_end]

        if right in freq:
            freq[right] -= 1
            if freq[right] == 0:
                matched += 1

        if matched == len(freq):
            return True

        if window_end >= len(pattern) - 1:
            left = s[window_start]
            window_start += 1

            if left in freq:
                if freq[left] == 0:
                    matched -= 1
                freq[left] += 1

    return False

